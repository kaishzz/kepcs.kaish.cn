ZHUPAY_BASE_URL=https://example.com
ZHUPAY_CREATE_ORDER_PATH=/v1/order/create
ZHUPAY_QUERY_ORDER_PATH=/v1/order/query
ZHUPAY_API_VERSION=2.0
ZHUPAY_MERCHANT_NO=
ZHUPAY_PAYMENT_CHANNEL=
