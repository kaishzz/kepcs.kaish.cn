NODE_ENV=development
PORT=3000
TRUST_PROXY=false
APP_BASE_URL=http://localhost:3000
APP_BASE_PATH=/pay
CDK_BASE_PATH=/console
PUBLIC_SITE_NAME="KepCs 开水服"
SESSION_SECRET=replace-with-a-strong-random-secret
ROOT_STEAM_IDS=76561198000000000
ADMIN_STEAM_IDS=
STEAM_WEB_API_KEY=
