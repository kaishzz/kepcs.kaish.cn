ZHUPAY_RETURN_URL=https://example.com/pay/result
ZHUPAY_CREATE_EXTRA_FIELDS={}
ZHUPAY_SIGN_FIELD=sign
ZHUPAY_SIGN_TYPE=SHA256WithRSA
ZHUPAY_TIMESTAMP_TOLERANCE_SECONDS=300
